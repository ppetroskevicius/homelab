network:
  version: 2
  renderer: networkd
  ethernets:
    {{ physical_interface }}:
      dhcp4: false
      dhcp6: false
  bridges:
    br0:
      interfaces:
        - {{ physical_interface }}
      addresses:
        - {{ bridge_ip }}/24
{% if gateway is defined %}
      routes:
        - to: default
          via: {{ gateway }}
{% else %}
      gateway4: 192.168.20.1
{% endif %}
      nameservers:
        addresses:
          - 1.1.1.1
          - 8.8.8.8
      parameters:
        stp: false
        forward-delay: 0
      dhcp4: false
      dhcp6: false
