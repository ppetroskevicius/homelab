# terraform.tfvars.example
# Copy to terraform.tfvars and fill in your values
#
# cp terraform.tfvars.example terraform.tfvars
# Then edit terraform.tfvars with your SSH public key

# Libvirt connection URI
# Default connects to bm-hypervisor-01 via SSH
libvirt_uri = "qemu+ssh://fastctl@192.168.20.20/system"

# SSH public key for VM access
# Get your public key with: cat ~/.ssh/id_ed25519.pub
# Or from 1Password: op read "op://Personal/ssh-key-ed25519/public key"
ssh_public_key = "ssh-ed25519 AAAA... your-key-here"

# Storage pool (default is usually fine)
storage_pool = "default"

# Network bridge on the hypervisor
bridge_name = "br0"

# Network configuration
network_gateway = "192.168.20.1"
network_dns     = ["1.1.1.1", "8.8.8.8"]

# VM user
vm_user = "fastctl"

# VM definitions (defaults are set in variables.tf)
# Uncomment and modify to customize:
