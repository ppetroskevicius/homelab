{{- $isWork := and (hasKey . "is_work") .is_work -}}
# Oh My Zsh configuration
# Note: common.sh is sourced in .zprofile (login shell) to avoid duplicate PATH entries
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="robbyrussell"
setopt histignorealldups
# zsh-syntax-highlighting must be LAST in this list: it wraps the ZLE widgets,
# so any plugin loaded after it goes unhighlighted.
plugins=(git zsh-autosuggestions terraform gcloud docker kubectl zsh-syntax-highlighting)
# It re-tokenizes the whole buffer on every keystroke, so cost grows with line
# length (~10ms/keystroke at 4KB — visible lag when editing a pasted command).
# Past this many chars it stops highlighting instead; short commands are the
# 99% case and are unaffected.
ZSH_HIGHLIGHT_MAXLENGTH=512
source $ZSH/oh-my-zsh.sh

# Starship prompt (desktop only, installed via dotfiles)
if command -v starship >/dev/null 2>&1 && [ "${TERM-}" != "dumb" ]; then
  eval "$(starship init zsh)"
fi

# direnv - just-in-time secrets per project
if command -v direnv >/dev/null 2>&1; then
  eval "$(direnv hook zsh)"
fi

# mise - per-project tool version manager
if command -v mise >/dev/null 2>&1; then
  eval "$(mise activate zsh)"
fi
{{- if eq .chezmoi.os "darwin" }}

# gcloud SDK (Homebrew on macOS)
if [ -d "/opt/homebrew/share/google-cloud-sdk/bin" ]; then
  export PATH="/opt/homebrew/share/google-cloud-sdk/bin:$PATH"
  # Pin gcloud's own Python to Homebrew's python@3.14 (the gcloud-cli cask
  # dependency), independent of any active uv/project virtualenv. Avoids the
  # deprecated system Python 3.9 that gcloud otherwise falls back to.
  if [ -x "/opt/homebrew/bin/python3.14" ]; then
    export CLOUDSDK_PYTHON="/opt/homebrew/bin/python3.14"
  fi
fi
{{- end }}

### MANAGED BY RANCHER DESKTOP START (DO NOT EDIT)
export PATH="$HOME/.rd/bin:$PATH"
### MANAGED BY RANCHER DESKTOP END (DO NOT EDIT)

# Deno
export DENO_INSTALL="$HOME/.deno"
export PATH="$DENO_INSTALL/bin:$PATH"

# De-duplicate PATH keeping first occurrence. Runs last, after every prepend
# above, so it collapses repeats (e.g. google-cloud-sdk/bin) that scalar
# `export PATH=` assignments reintroduce. Complements the ordering fix in
# .zprofile. zsh-only syntax.
# shellcheck disable=SC3030,SC3044
typeset -U path
