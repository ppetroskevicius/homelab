{{- $isDesktop := or (eq (get . "machine_type") "desktop") (hasPrefix "dt-" .chezmoi.hostname) -}}
{{- $isWork := and (hasKey . "is_work") .is_work -}}
# Global settings
Host *
{{- if and $isDesktop (not $isWork) }}
  # Personal desktop: 1Password SSH Agent
  {{- if eq .chezmoi.os "darwin" }}
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"
  {{- else }}
  IdentityAgent ~/.1password/agent.sock
  {{- end }}
{{- end }}
  ForwardAgent yes
  AddKeysToAgent yes
{{- if and $isWork (eq .chezmoi.os "darwin") }}
  UseKeychain yes
{{- end }}
  Compression yes
{{- if not $isWork }}
  User fastctl
{{- end }}

{{- if not $isWork }}

# Bare Metal Hypervisors
Host bm-hypervisor-01
  HostName 192.168.20.20

Host bm-hypervisor-02
  HostName 192.168.20.33

Host bm-hypervisor-03
  HostName 192.168.20.22

Host bm-hypervisor-04
  HostName 192.168.10.194

# Kubernetes Nodes
Host vm-k8s-node-01
  HostName 192.168.20.51

Host vm-k8s-node-02
  HostName 192.168.20.52

Host vm-k8s-node-03
  HostName 192.168.20.53

# Dev Container Host
Host vm-dev-container-01
  HostName 192.168.20.61

# Service VM
Host vm-service
  HostName 192.168.20.71

# Desktops
Host dt-dev-01
  HostName 192.168.10.189

Host dt-dev-02
  HostName 192.168.10.135

Host dt-dev-03
  HostName 192.168.10.136

Host dt-dev-04
  HostName 192.168.10.137

Host dt-dev-05
  HostName 192.168.10.138

{{- end }}

{{- if $isWork }}
# Work GitHub (default — git clone git@github.com:org/repo.git just works)
Host github.com
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519

# Personal GitHub (use: git clone git@github-personal:user/repo.git)
Host github-personal
  HostName github.com
  User git
  IdentityFile ~/.ssh/id_ed25519_personal
  IdentitiesOnly yes
{{- else }}
# GitHub - 1Password handles key selection
Host github.com
  HostName github.com
  User git
{{- end }}
