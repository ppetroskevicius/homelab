{{- $isWork := and (hasKey . "is_work") .is_work -}}
[user]
	name = ppetroskevicius
	email = p.petroskevicius@gmail.com
[pull]
  rebase = false
[push]
  autoSetupRemote = true
[core]
  editor = vim

# Enforce SSH
[url "ssh://git@github.com/"]
  insteadOf = https://github.com/
[init]
	defaultBranch = main
{{- if $isWork }}

# Work machine: include work-specific gitconfig (not tracked in this repo)
# Create ~/.gitconfig-work manually with [user] name/email overrides
[includeIf "gitdir:~/work/"]
  path = ~/.gitconfig-work
{{- end }}
